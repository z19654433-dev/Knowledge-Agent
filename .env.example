# ============================================================
# 配置模板：复制本文件为 .env 并填入你自己的真实密钥
#   cp .env.example .env
# 注意：.env 已被 .gitignore 忽略，不会上传到 Git 仓库
# ============================================================

# ── LLM 提供商选择 ──
# 可选值: deepseek | openai_compatible
#   deepseek          : 使用 DeepSeek 官方 API（默认）
#   openai_compatible : 兼容 OpenAI SDK 的第三方模型（智谱 GLM / 通义千问 / 零一 Yi 等）
LLM_PROVIDER=deepseek

# ── DeepSeek 配置（LLM_PROVIDER=deepseek 时生效）──
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ── OpenAI 兼容配置（LLM_PROVIDER=openai_compatible 时生效）──
# OPENAI_API_KEY=sk-your-thirdparty-key-here
# OPENAI_BASE_URL=https://your-provider-endpoint/v1
# OPENAI_MODEL_NAME=your-model-name

# ── 知识库 RAG 配置（均为可选，留空则使用下方默认值）──
# KNOWLEDGE_DOCS_DIR=knowledge/docs
# KNOWLEDGE_CHUNK_SIZE=500
# KNOWLEDGE_CHUNK_OVERLAP=50
# KNOWLEDGE_RETRIEVE_TOP_K=3
# KNOWLEDGE_EMBEDDING=default          # default | sentence-transformers | api
# KNOWLEDGE_VECTOR_STORE=chroma        # chroma | faiss(预留)
