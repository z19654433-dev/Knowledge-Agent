# ============================================================
# 配置模板：复制本文件为 .env 并填入你自己的真实密钥
#   cp .env.example .env
# 注意：.env 已被 .gitignore 忽略，不会上传到 Git 仓库
# ============================================================

# ── LLM 默认提供商 ──
# 前端未指定模型时的默认值，可选: deepseek | glm | qwen | yi
LLM_PROVIDER=deepseek

# ============================================================
# 前端「模型切换器」四个厂商：各自独立的 key，填了哪个哪个才能用
# base_url / model 均有默认值，一般无需修改；只需填 *_API_KEY
# ============================================================

# ── DeepSeek（默认，通用助手）──
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ── 智谱 GLM（创意写作）──
# GLM_API_KEY=your-zhipu-key-here
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# GLM_MODEL=glm-4-flash

# ── 通义千问（逻辑分析）──
# QWEN_API_KEY=your-dashscope-key-here
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-turbo

# ── 零一万物 Yi（头脑风暴）──
# YI_API_KEY=your-lingyiwanwu-key-here
# YI_BASE_URL=https://api.lingyiwanwu.com/v1
# YI_MODEL=yi-lightning

# ── OpenAI 兼容配置（旧版保留，可忽略）──
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL_NAME=

# ── 知识库 RAG 配置（均为可选，留空则使用下方默认值）──
# KNOWLEDGE_DOCS_DIR=knowledge/docs
# KNOWLEDGE_CHUNK_SIZE=500
# KNOWLEDGE_CHUNK_OVERLAP=50
# KNOWLEDGE_RETRIEVE_TOP_K=3
# KNOWLEDGE_EMBEDDING=default          # default | sentence-transformers | api
# KNOWLEDGE_VECTOR_STORE=chroma        # chroma | faiss(预留)

# ── Obsidian 个人知识库（可选，连接本地 vault）──
# vault 路径：本地文件夹（含 .obsidian 目录即为有效 vault）
# OBSIDIAN_VAULT_DIR=D:\agent\obsidain\知识库
# OBSIDIAN_COLLECTION=obsidian          # 独立向量集合名，与 knowledge/docs 隔离
# OBSIDIAN_EXCLUDE=API.md               # 排除清单(逗号分隔)：这些文件/文件夹永不被索引或读取(隐私保护)
#                                       #   支持 文件名(API.md) / 相对路径(secret/api.md) / 文件夹名(.trash)
# OBSIDIAN_WATCHER_ENABLED=true         # 是否启用实时文件监视（vault 未配置时自动跳过）
# OBSIDIAN_WATCH_INTERVAL=5             # 防抖/轮询间隔(秒)。watchdog 下为「变更后多久重索引」合并窗口；
#                                       #   未装 watchdog 时回退为「每隔多少秒扫描一次」
# 说明：实时监视优先用 watchdog（毫秒级），需 pip install watchdog；未安装则自动回退 stdlib 轮询(延迟=间隔)
